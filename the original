    """Sistema de invasão"""
    try:
        query = update.callback_query
        
        dados = carregar_dados()
        user_id = str(update.effective_user.id)
        
        if user_id not in dados["players"]:
            return
        
        player = dados["players"][user_id]
        
        agora = time.time()
        if agora - player.get("ultimo_invasao", 0) < COOLDOWN_INVASAO:
            tempo_falta = int(COOLDOWN_INVASAO - (agora - player.get("ultimo_invasao", 0)))
            await query.answer(f"⏳ Cooldown: {tempo_falta}s")
            return
        
        alvos = [p for p in dados["players"].values() if p["casa"] and p["nome"] != player["nome"] and p["status"] == "vivo"]
        
        if not alvos:
            await query.answer("❌ Sem casas para invadir!")
            return
        
        alvo = random.choice(alvos)
        sucesso = random.randint(1, 100) > 40
        
        if sucesso:
            roubo = random.randint(100, 500)
            alvo["ouro"] = max(0, alvo["ouro"] - roubo)
            player["ouro"] += roubo
            res = f"✅ **INVASÃO BEM-SUCEDIDA!**\n\nRoubou {roubo} ouro de {alvo['nome']}!"
        else:
            res = f"❌ **INVASÃO FRACASSADA!**"
            player["energia"] = max(0, player["energia"] - 50)
        
        player["ultimo_invasao"] = agora
        salvar_dados(dados)
        
        await query.answer("🏠 Invasão!")
        await query.edit_message_text(res, parse_mode="Markdown")
