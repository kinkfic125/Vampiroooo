async def executar_craft(update: Update, context: ContextTypes.DEFAULT_TYPE, tipo: str):
    """Executar craft"""
    try:
        query = update.callback_query
        
        dados = carregar_dados()
        user_id = str(update.effective_user.id)
        vips = carregar_vips()
        
        if user_id not in dados["players"]:
            await query.answer("❌ Jogador não encontrado!")
            return
        
        player = dados["players"][user_id]
        
        vip_bonus = 1.5 if user_id in vips["vips_premium"] else (1.25 if user_id in vips["vips"] else 1)
        
        receitas = {
            "cura": {"ing": {"Sangue Antigo": 2}, "res": "Poção de Cura", "xp": 25},
            "forca": {"ing": {"Grimório": 1, "Sangue Antigo": 1}, "res": "Poção de Força", "xp": 30},
            "elixir": {"ing": {"Cálice": 1}, "res": "Elixir de Vida", "xp": 50},
            "ritual": {"ing": {"Cristal": 1}, "res": "Ritual de Poder", "xp": 75},
            "maldicao": {"ing": {"Essência": 2}, "res": "Maldição Ancestral", "xp": 100},
            "velocidade": {"ing": {"Adaga": 1, "Essência": 1}, "res": "Poção de Velocidade", "xp": 40}
        }
        
        if tipo not in receitas:
            await query.answer("❌ Craft inválido!")
            return
        
        receita = receitas[tipo]
        
        # Verificar ingredientes
        for ing, qtd in receita["ing"].items():
            tem = False
            for item in player["inventario"]:
                if item["nome"] == ing and item["quantidade"] >= qtd:
                    tem = True
                    break
            if not tem:
                await query.answer(f"❌ Faltam: {qtd}x {ing}")
                return
        
        # Remover ingredientes
        for ing, qtd in receita["ing"].items():
            for item in player["inventario"]:
                if item["nome"] == ing:
                    item["quantidade"] -= qtd
                    if item["quantidade"] <= 0:
                        player["inventario"].remove(item)
                    break
        
        # Adicionar resultado
        tem = False
        for item in player["inventario"]:
            if item["nome"] == receita["res"]:
                item["quantidade"] += 1
                tem = True
                break
        
        if not tem:
            player["inventario"].append({"nome": receita["res"], "quantidade": 1})
        
        xp = int(receita["xp"] * vip_bonus)
        ganhar_xp(player, xp, vip_bonus)
        player["rituais_feitos"] += 1
        salvar_dados(dados)
        
        await query.answer("✅ Craftado!")
        await query.edit_message_text(
            f"✅ **{receita['res']}**\n\n"
            f"+{xp} XP {'(+VIP Bonus!)' if vip_bonus > 1 else ''}",
            parse_mode="Markdown"
        )
    except Exception as e:
        logger.error(f"Erro em executar_craft: {e}")

