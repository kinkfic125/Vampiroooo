def obter_hora_atual():
    hora = datetime.now().hour
    return 6 <= hora < 18

def aplicar_bonus_dia_noite(player, base_valor):
    eh_dia = obter_hora_atual()
    if player["classe"] == "Humano" and eh_dia:
        return int(base_valor * 1.3)
    elif player["classe"] in ["Vampiro", "Original"] and not eh_dia:
        return int(base_valor * 1.3)
    elif player["classe"] == "Lobisomem" and not eh_dia:
        return int(base_valor * 1.2)
    return base_valor

def calcular_idade_vampiro(data_transformacao):
    if not data_transformacao:
        return 0
    try:
        if isinstance(data_transformacao, str):
            data = datetime.fromisoformat(data_transformacao)
        else:
            return 0
        agora = datetime.now()
        idade = (agora - data).days / 365.25
        return int(idade)
    except:
        return 0

def calcular_poder(classe, idade, nivel, prestige=0):
    if classe == "Humano":
        return 0
    
    bonus_idade = min(idade * 0.5, 500)
    bonus_nivel = nivel * 5
    bonus_prestige = prestige * 10
    
    bonus_classe = {
        "Vampiro": 50,
        "Lobisomem": 40,
        "Bruxo": 45,
        "Híbrido": 70,
        "Original": 150,
        "Deus": 250
    }.get(classe, 0)
    
    return int(bonus_classe + bonus_idade + bonus_nivel + bonus_prestige)

