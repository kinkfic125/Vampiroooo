async def atacar(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Atacar outro jogador"""
    try:
        query = update.callback_query
        
        dados = carregar_dados()
        user_id = str(update.effective_user.id)
        vips = carregar_vips()
        
        if user_id not in dados["players"]:
            return
        
        player = dados["players"][user_id]
        
        if player["classe"] == "Humano":
            await query.answer("❌ Humanos não podem atacar!")
            return
        
        cooldown = COOLDOWN_ATAQUE
        if user_id in vips["vips_premium"]:
            cooldown = int(cooldown * 0.5)
        elif user_id in vips["vips"]:
            cooldown = int(cooldown * 0.75)
        
        agora = time.time()
        if agora - player["ultimo_ataque"] < cooldown:
            tempo_falta = int(cooldown - (agora - player["ultimo_ataque"]))
            await query.answer(f"⏳ Aguarde {tempo_falta}s")
            return
        
        alvos = [p for p in dados["players"].values() if p["nome"] != player["nome"] and p["status"] == "vivo"]
        if not alvos:
            await query.answer("❌ Sem alvos!")
            return
        
        alvo = random.choice(alvos)
        
        bonus_idade = player["idade_vampiro"] * 0.5 if player["classe"] != "Humano" else 0
        dano_base = random.randint(player["ataque"], player["ataque"] + 20)
        dano = int((dano_base + bonus_idade) - alvo["defesa"])
        dano = max(1, dano)
        
        dano = aplicar_bonus_dia_noite(player, dano)
        
        alvo["saude"] -= dano
        player["ultimo_ataque"] = agora
        player["combo_count"] += 1
        
        if alvo["saude"] <= 0:
            alvo["status"] = "morto"
            alvo["mortes"] += 1
            player["kills"] += 1
            ganhar_xp(player, 100)
            bonus_combo = player["combo_count"] * 10
            player["ouro"] += bonus_combo
            res = f"💀 **{alvo['nome']} MORREU!**\n\nBonus combo: +{bonus_combo} ouro"
        else:
            ganhar_xp(player, 25)
            res = f"⚔️ Dano: {dano}\nSaúde: {max(0, alvo['saude'])}/100"
        
        salvar_dados(dados)
        
        eh_dia = "☀️" if obter_hora_atual() else "🌙"
        await query.answer("⚔️ Ataque!")
        await query.edit_message_text(f"⚔️ **{alvo['nome']}** {eh_dia}\n\n{res}", parse_mode="Markdown")
    except Exception as e:
        logger.error(f"Erro em atacar: {e}")

