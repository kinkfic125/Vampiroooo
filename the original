async def comprar_item(update: Update, context: ContextTypes.DEFAULT_TYPE, item: str, preco: int):
    """Comprar item na loja"""
    try:
        query = update.callback_query
        
        dados = carregar_dados()
        user_id = str(update.effective_user.id)
        vips = carregar_vips()
        
        if user_id not in dados["players"]:
            await query.answer("❌ Jogador não encontrado!")
            return
        
        player = dados["players"][user_id]
        
        desconto = 30 if user_id in vips["vips_premium"] else (15 if user_id in vips["vips"] else 0)
        preco_final = int(preco * (1 - desconto/100))
        
        if player["ouro"] < preco_final:
            await query.answer("❌ Sem ouro!")
            return
        
        player["ouro"] -= preco_final
        
        tem = False
        for i in player["inventario"]:
            if i["nome"] == item:
                i["quantidade"] += 1
                tem = True
                break
        
        if not tem:
            player["inventario"].append({"nome": item, "quantidade": 1})
        
        salvar_dados(dados)
        
        desc = f" (-{desconto}%)" if desconto > 0 else ""
        await query.answer("✅ Comprado!")
        await query.edit_message_text(
            f"✅ **{item}**\n\n"
            f"Preço: {preco_final}${desc}\n"
            f"💰 Resto: {player['ouro']}",
            parse_mode="Markdown"
        )
    except Exception as e:
        logger.error(f"Erro em comprar_item: {e}")

