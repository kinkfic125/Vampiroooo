def ganhar_xp(player, qtd, bonus_vip=1):
    xp_final = int(qtd * bonus_vip)
    player["xp"] += xp_final
    xp_necessario = player["nivel"] * 100
    
    if player["xp"] >= xp_necessario:
        player["nivel"] += 1
        player["xp"] = 0
        player["ataque"] += 2
        player["saude"] += 10
        player["skill_points"] += 3
        player["poder"] = calcular_poder(player["classe"], player["idade_vampiro"], player["nivel"], player["prestige"])
        return True
    return False

